# ============================================
# PLESIR PEKALONGAN - Environment Variables
# ============================================
# Copy file ini ke .env (tanpa .example) dan isi dengan nilai Anda
# JANGAN PERNAH commit file .env ke Git!

# ============================================
# REQUIRED: Google Gemini API Key
# ============================================
# Dapatkan di: https://aistudio.google.com/apikey
# Free tier: 15 req/menit, 1500 req/hari
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# ============================================
# OPTIONAL: Analytics & Monitoring
# ============================================
# Vercel Analytics tidak butuh env var (auto-detect)
# Google Analytics 4 (opsional)
# VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Sentry Error Tracking (opsional)
# VITE_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# ============================================
# OPTIONAL: Custom Configurations
# ============================================
# Base URL untuk production (auto-detect oleh Vercel)
# VITE_BASE_URL=https://plesirpekalongan.id

# Feature flags
# VITE_ENABLE_PWA=true
# VITE_ENABLE_OFFLINE=true
